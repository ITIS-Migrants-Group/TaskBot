version: '3.8'

services:
  todo-db:
    image: postgres:16
    container_name: todo_db
    environment:
      POSTGRES_DB: todo_db
      POSTGRES_USER: todo_user
      POSTGRES_PASSWORD: todo_password
    ports:
      - "5434:5432"
    volumes:
      - todo_db_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U todo_user -d todo_db"]
      interval: 5s
      timeout: 5s
      retries: 5

  todo-service:
      build: .
      container_name: todo_app
      environment:
        SPRING_DATASOURCE_URL: jdbc:postgresql://todo-db:5432/todo_db
        SPRING_DATASOURCE_USERNAME: todo_user
        SPRING_DATASOURCE_PASSWORD: todo_password
      ports:
        - "8065:8065"
      depends_on:
        todo-db:
          condition: service_healthy   # ждём, пока БД будет готова
      restart: on-failure
volumes:
  todo_db_data: